---
import Layout from "@layouts/Layout.astro";
import Background from "@components/Background.astro";
import NavList from "@components/NavList.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";

const navPages = {
	"/": Astro.site?.hostname ?? "Home",
	"/blog": "Blog",
};
---

<Layout>
	<Background />
	<page-wrapper class="panel-dark">
		<title-bar class="panel-dark">
			<NavList navPages={navPages} />
			<Breadcrumbs ignoredPages={Object.keys(navPages)} />
		</title-bar>
		<page-container>
			<slot />
		</page-container>
		<footer></footer>
	</page-wrapper>
</Layout>

<style>
	title-bar {
		display: block;
		position: sticky;
		top: 0;
		z-index: 100;
	}
	footer {
		border-top: 2px solid var(--color-light);
		padding: 3rem;
	}

	page-wrapper {
		flex-grow: 1;
		width: 100%;
		max-width: 180rem;
		margin: 0 auto;
		/* Outline will not render for screens slimmer than the max width */
		outline: 2px solid var(--color-light);
	}
	page-container {
		flex-grow: 1;
		display: flex;
		flex-direction: column;
	}
	page-container > :global(main) {
		padding: 3rem 3rem;
	}
</style>
